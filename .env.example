# =============================================================================
# Vault Token Refresh - Configuration
# =============================================================================
#
# SETUP:
#   1. Copy this file:       cp .env.example ~/.vault-refresh.env
#   2. Lock permissions:      chmod 600 ~/.vault-refresh.env
#   3. Fill in your values below
#   4. Write the initial secret_id to its file (see VAULT_APPROLE_SECRET_ID_FILE)
#   5. Run:                   ./refresh-vault-token.sh
#
# WHAT THIS SCRIPT DOES:
#   - Authenticates to Vault using AppRole (role_id + secret_id) or cloud identity
#   - Pushes the resulting Vault token into an Akeyless HashiVault target
#   - Self-schedules the next run at 75% of the token TTL (e.g. every ~10.5 days
#     for a 14-day token)
#   - Optionally rotates the AppRole secret_id before it expires
#
# WHAT YOUR VAULT ADMIN NEEDS TO PROVIDE:
#   - A role_id and secret_id for AppRole authentication
#   - The Vault policy applied to the AppRole role must include:
#
#     # Read secrets (what the Akeyless USC needs)
#     path "secret/data/*"          { capabilities = ["create","read","update","delete","list"] }
#     path "secret/metadata/*"      { capabilities = ["read","list","delete"] }
#     path "sys/mounts"             { capabilities = ["read"] }
#     path "sys/mounts/*"           { capabilities = ["read"] }
#     path "auth/token/lookup-self" { capabilities = ["read"] }
#
#     # Secret ID self-rotation (required if SECRET_ID_MIN_DAYS > 0)
#     # Replace <MOUNT> with VAULT_APPROLE_MOUNT and <ROLE> with VAULT_APPROLE_ROLE_NAME
#     path "auth/<MOUNT>/role/<ROLE>/secret-id"         { capabilities = ["update"] }
#     path "auth/<MOUNT>/role/<ROLE>/secret-id/lookup"   { capabilities = ["update"] }
#     path "auth/<MOUNT>/role/<ROLE>/secret-id/destroy"  { capabilities = ["update"] }
#
# DEPENDENCIES: curl, jq, at (atd service must be running for self-scheduling)
# =============================================================================

# --- Vault Connection ---
VAULT_ADDR=http://127.0.0.1:8200

# --- Vault Auth ---
# Method: "gcp", "azure", or "approle"
VAULT_AUTH_METHOD=approle

# AppRole auth (when VAULT_AUTH_METHOD=approle):
VAULT_APPROLE_ROLE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULT_APPROLE_ROLE_NAME=your-role-name
VAULT_APPROLE_SECRET_ID_FILE=~/.vault-approle-secret-id
# VAULT_APPROLE_MOUNT=approle

# Cloud auth (when VAULT_AUTH_METHOD=gcp or azure):
# VAULT_ROLE=usc-token-role

# --- Secret ID Rotation ---
# When the secret_id has fewer than this many days left, generate a new one.
# Requires the 3 secret-id policy paths above. Set to 0 to disable.
SECRET_ID_MIN_DAYS=30

# --- Akeyless ---
AKEYLESS_API=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxxxxxx
AKEYLESS_ACCESS_TYPE=universal_identity
AKEYLESS_TARGET_NAME=/Path/to/vault-target
VAULT_URL=https://vault.example.com

# UID token file (when AKEYLESS_ACCESS_TYPE=universal_identity):
UID_TOKEN_FILE=~/.vault-refresh-uid-token

# --- Scheduling ---
# Fraction of token TTL to wait before refreshing (0.75 = refresh at 75% of TTL)
REFRESH_RATIO=0.75
# Set to false to disable self-scheduling (useful if you run this via cron instead)
SELF_SCHEDULE=true

# --- Optional ---
# A Vault secret path to read after auth to verify the token works
# VERIFY_PATH=secret/data/test-app/db
LOG_FILE=/var/log/refresh-vault-token.log
