# Vault Token Refresh Configuration
# Copy to ~/.vault-refresh.env and fill in values
# chmod 600 ~/.vault-refresh.env

# --- Vault ---
VAULT_ADDR=http://127.0.0.1:8200

# --- Vault Auth Method: "gcp", "azure", or "approle" ---
# VAULT_AUTH_METHOD takes precedence; CLOUD_PROVIDER is accepted for backward compat
VAULT_AUTH_METHOD=approle

# Cloud auth only (gcp/azure):
# VAULT_ROLE=usc-token-role
# CLOUD_PROVIDER=gcp

# AppRole auth only:
VAULT_APPROLE_ROLE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULT_APPROLE_SECRET_ID_FILE=~/.vault-approle-secret-id
# VAULT_APPROLE_MOUNT=approle  # default: approle

# --- Akeyless API ---
AKEYLESS_API=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxxxxxx
# For approle, use universal_identity (no cloud identity available)
AKEYLESS_ACCESS_TYPE=universal_identity
AKEYLESS_TARGET_NAME=/Path/to/vault-target
VAULT_URL=https://vault.example.com

# --- UID Auth (if AKEYLESS_ACCESS_TYPE=universal_identity) ---
UID_TOKEN_FILE=~/.vault-refresh-uid-token

# --- Scheduling ---
REFRESH_RATIO=0.75
SELF_SCHEDULE=true

# --- Optional ---
VERIFY_PATH=secret/data/test-app/db
LOG_FILE=/var/log/refresh-vault-token.log
